# ============================================
# ARQUIVO .env.local.example
# Renomear para .env.local e preencher seus dados
# ============================================

# ============================================
# CONFIGURAÇÃO BÁSICA
# ============================================
NEXT_PUBLIC_APP_NAME=Terapias Integradas - Ana Carolina
NEXT_PUBLIC_APP_URL=http://localhost:3000
# ATENÇÃO: NÃO defina NODE_ENV manualmente. O Next.js define automaticamente
# (development no `next dev`, production no `next build`). Defini-lo aqui — ou
# nas Environment Variables da Vercel — quebra o build de produção.

# ============================================
# INFORMAÇÕES DO PROFISSIONAL
# ============================================
NEXT_PUBLIC_PROFESSIONAL_NAME=Dra. Ana Carolina Silva
NEXT_PUBLIC_PROFESSIONAL_PHONE=+55 11 99999-9999
NEXT_PUBLIC_PROFESSIONAL_EMAIL=contato@terapiaanacarolina.com.br
NEXT_PUBLIC_PROFESSIONAL_CREFITO=CREFITO: 123456-F
NEXT_PUBLIC_PROFESSIONAL_ADDRESS=São Paulo, SP - Brasil

# ============================================
# WHATSAPP - OPÇÃO 1: WhatsApp Web (Mais Fácil)
# ============================================
# Este é o valor mínimo necessário
# Os links WhatsApp funcionam AUTOMATICAMENTE
# Você NÃO precisa fazer nada aqui para começar
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER=+5511999999999

# ============================================
# WHATSAPP - OPÇÃO 2: WhatsApp API (Profissional)
# Deixe em branco se usar apenas WhatsApp Web
# ============================================

# PASSO 1: Obtenha em https://developers.facebook.com
# - Crie app tipo "Business"
# - Adicione produto "WhatsApp"
# - Obtenha phone number ID e tokens

NEXT_PUBLIC_WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
NEXT_PUBLIC_WHATSAPP_API_VERSION=v18.0

# ============================================
# N8N - AUTOMAÇÕES (Opcional)
# ============================================

# PASSO 1: Criar conta em https://n8n.io
# PASSO 2: Criar webhooks para seus workflows
# PASSO 3: Copiar URLs aqui

# URL base do webhook
N8N_WEBHOOK_URL=https://n.msautosystems.tech/webhook-test/carvalho-digital-terapia

# URLs específicas por tipo de workflow
N8N_WEBHOOK_AUTH_KEY=https://n.msautosystems.tech/webhook-test/carvalho-digital-terapia
N8N_WORKFLOW_CONTACT_FORM=https://n.msautosystems.tech/webhook-test/carvalho-digital-terapia
N8N_WORKFLOW_SCHEDULE_APPOINTMENT=
N8N_WORKFLOW_SEND_WHATSAPP=

# ============================================
# EMAIL (EmailJS - Opcional)
# ============================================

# Criar conta em https://www.emailjs.com
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# ============================================
# SMTP (Alternativa para Email)
# ============================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua_senha_app

# ============================================
# ANALYTICS
# ============================================

# Google Analytics
NEXT_PUBLIC_GA_ID=

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=

# ============================================
# REDES SOCIAIS
# ============================================

NEXT_PUBLIC_INSTAGRAM=https://instagram.com/anacarolina.terapias
NEXT_PUBLIC_FACEBOOK=https://facebook.com/terapiasintegradas
NEXT_PUBLIC_LINKEDIN=https://linkedin.com/in/anacarolinaterapias

# ============================================
# DEBUG
# ============================================

DEBUG_MODE=false

# ============================================
# EXPLICAÇÕES DETALHADAS
# ============================================

# 🟢 ESSENCIAL (Preencher obrigatoriamente):
# - NEXT_PUBLIC_PROFESSIONAL_NAME
# - NEXT_PUBLIC_PROFESSIONAL_PHONE
# - NEXT_PUBLIC_PROFESSIONAL_EMAIL

# 🟡 RECOMENDADO (Preencher se possível):
# - NEXT_PUBLIC_PROFESSIONAL_CREFITO
# - NEXT_PUBLIC_INSTAGRAM
# - NEXT_PUBLIC_GA_ID (para analytics)

# 🔴 OPCIONAL (Preencher apenas se usar):
# - WHATSAPP_API_TOKEN (se usar API)
# - N8N_WEBHOOK_URL (se usar automações)
# - EMAILJS_* (se usar email via EmailJS)
# - SMTP_* (se usar email via SMTP)

# ============================================
# COMO PREENCHER CADA CAMPO
# ============================================

# PROFESSIONAL_PHONE:
# Formato: +55 11 99999-9999 ou +5511999999999
# Obtenha seu número WhatsApp Business

# PROFESSIONAL_CREFITO:
# Formato: CREFITO: 388275-F
# Seu número de registro profissional

# WHATSAPP_PHONE_NUMBER_ID:
# Obtenha em: Facebook Developer > Seu App > WhatsApp > Configuration
# Exemplo: 123456789

# WHATSAPP_API_TOKEN:
# Obtenha em: Facebook Developer > Seu App > Settings > Basic
# Formato: EAAx...token_muito_longo...xyz

# N8N_WEBHOOK_URL:
# Criar em: n8n.io > Novo Workflow > Webhook
# Exemplo: https://seu-n8n.com/webhook/contact-form
# Ou usar n8n cloud: https://seu-instancia.n8n.cloud/webhook

# GA_ID:
# Obtenha em: Google Analytics > Admin > Data Streams
# Formato: G-XXXXXXXXXX

# GTM_ID:
# Obtenha em: Google Tag Manager > Admin > Containers
# Formato: GTM-XXXXXXX

# ============================================
# INSTRUÇÕES POR CENÁRIO
# ============================================

# CENÁRIO 1: Iniciante (Apenas WhatsApp Web)
# Preencher apenas:
# - PROFESSIONAL_NAME
# - PROFESSIONAL_PHONE
# - PROFESSIONAL_EMAIL
# Tudo mais deixar vazio

# CENÁRIO 2: Intermediário (Com Automações)
# Preencher:
# - Dados profissional (acima)
# - N8N webhooks
# - Google Analytics

# CENÁRIO 3: Avançado (Todas as integrações)
# Preencher:
# - Todos os campos de profissional
# - WhatsApp API (opcional)
# - N8N webhooks
# - Email (EmailJS ou SMTP)
# - Analytics

# ============================================
# SEGURANÇA
# ============================================

# ⚠️ NUNCA commitar este arquivo no Git!
# Adicione ao .gitignore

# ⚠️ NUNCA compartilhar tokens/chaves publicamente

# ⚠️ Usar variáveis separadas para dev/prod
# .env.local (desenvolvimento)
# .env.production (produção)

# ============================================
# TESTES
# ============================================

# Para testar localmente:
# 1. Preencher PROFESSIONAL_NAME e PHONE
# 2. npm run dev
# 3. Abrir http://localhost:3000
# 4. Clicar em WhatsApp CTA
# 5. Deve abrir WhatsApp Web

# ============================================
# SUPORTE
# ============================================

# Dúvidas sobre um campo?
# 1. Ver README.md
# 2. Consultar documentação oficial do serviço
# 3. Procurar no Google
# 4. Abrir issue no repositório
